# ===== ANTHROPIC =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== LANGSMITH =====
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=crypto-high-prob-scalper
LANGCHAIN_TRACING_V2=true

# ===== COINGLASS =====
COINGLASS_API_KEY=...

# ===== BYBIT =====
BYBIT_DEMO_API_KEY=...
BYBIT_DEMO_API_SECRET=...
BYBIT_LIVE_API_KEY=...
BYBIT_LIVE_API_SECRET=...

# ===== MONGODB =====
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/crypto-scalper
MONGODB_DATABASE=crypto-scalper

# ===== AZURE =====
AZURE_KEY_VAULT_URL=https://crypto-scalper-kv.vault.azure.net/

# ===== BOT CONFIG =====
MODE=BACKTEST  # BACKTEST | PAPER | LIVE
INITIAL_CAPITAL=100
LEVERAGE=10
CONFLUENCE_THRESHOLD=0.75
WIN_RATE_TARGET=0.80

# ===== TRADING HOURS (GMT-3 Argentina) =====
TRADING_START_ART=03:30  # 3:30 AM
TRADING_END_ART=13:30    # 1:30 PM
CANDLE_INTERVAL=1m

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_DIR=logs/
